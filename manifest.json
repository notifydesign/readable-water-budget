{
  "manifest_version": 3,
  "name": "Readable Water Budget",
  "version": "1.0.0",
  "description": "A clean water-budget dashboard for the Waterscope meter portal. See how much you've used, how much is left, and whether you're on track.",
  "icons": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" },
  "content_scripts": [
    {
      "matches": ["https://waterscope.us/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["fonts/*.woff2"],
      "matches": ["https://waterscope.us/*"]
    }
  ],
  "permissions": ["storage"],
  "host_permissions": ["https://waterscope.us/*", "https://raw.githubusercontent.com/*"]
}
